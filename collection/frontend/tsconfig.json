{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true
  },
  "include": ["**/*.js", "types.d.ts"],
  "exclude": [
    "vendor/**",
    "node_modules",
    "app.js",
    "config.js",
    "results/data.js",
    "results/results.js",
    "results/render.js",
    "results/sidebar.js",
    "results/browser.js",
    "results/status.js",
    "results/edits.js"
  ]
}
